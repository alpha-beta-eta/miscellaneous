(define (ev e v)
  (match e
    (,b (guard (boolean? b)) b)
    (,x (guard (symbol? x)) (v x))
    ((not ,e1) (not (ev e1 v)))
    ((and ,e1 ,e2) (and (ev e1 v) (ev e2 v)))
    ((or ,e1 ,e2) (or (ev e1 v) (ev e2 v)))
    ((=> ,e1 ,e2) (or (not (ev e1 v)) (ev e2 v)))
    ((<=> ,e1 ,e2) (eq? (ev e1 v) (ev e2 v)))))
(define (onAtoms f e)
  (match e
    (,b (guard (boolean? b)) b)
    (,x (guard (symbol? x)) (f x))
    ((not ,e1) `(not ,(onAtoms f e1)))
    ((,op ,e1 ,e2)
     `(,op ,(onAtoms f e1)
           ,(onAtoms f e2)))))
(define (atoms e)
  (match e
    (,b (guard (boolean? b)) '())
    (,x (guard (symbol? x)) (list x))
    ((not ,e1) (atoms e1))
    ((,op ,e1 ,e2) (U (atoms e1) (atoms e2)))))
(define (allv f v a*)
  (if (null? a*)
      (f v)
      (let ((a (car a*))
            (a* (cdr a*)))
        (define ((v^ b) x)
          (if (eq? x a) b (v x)))
        (and (allv f (v^ #f) a*)
             (allv f (v^ #t) a*)))))
(define (tautology? e)
  (allv (curry ev e)
        (lambda (x) #f)
        (atoms e)))
