#lang racket
(require "match.rkt")
(define (forall? pred lst)
  (cond ((null? lst) #t)
        ((pred (car lst))
         (forall? pred (cdr lst)))
        (else #f)))
(define (exists? pred lst)
  (cond ((null? lst) #f)
        ((pred (car lst)) #t)
        (else
         (exists? pred (cdr lst)))))
(define (fold-left proc init lst)
  (if (null? lst)
      init
      (fold-left proc (proc init (car lst)) (cdr lst))))
(define (remove-all x lst)
  (cond ((null? lst) '())
        ((equal? x (car lst))
         (remove-all x (cdr lst)))
        (else
         (cons (car lst) (remove-all x (cdr lst))))))
;set operations
(define (set-cons x s)
  (if (member x s)
      s
      (cons x s)))
(define (setlize x*)
  (if (null? x*)
      '()
      (set-cons (car x*)
                (setlize (cdr x*)))))
(define (U s1 s2)
  (cond ((null? s1) s2)
        ((member (car s1) s2) (U (cdr s1) s2))
        (else (cons (car s1) (U (cdr s1) s2)))))
(define U*
  (case-lambda
    (() '())
    ((s) s)
    ((s1 s2 . s*) (apply U* (U s1 s2) s*))))
(define (D s1 s2)
  (cond ((null? s1) '())
        ((member (car s1) s2) (D (cdr s1) s2))
        (else (cons (car s1) (D (cdr s1) s2)))))
(define (I? s1 s2)
  (cond ((null? s1) #f)
        ((member (car s1) s2) #t)
        (else (I? (cdr s1) s2))))
(define (subset? s1 s2)
  (cond ((null? s1) #t)
        ((member (car s1) s2)
         (subset? (cdr s1) s2))
        (else #f)))
